# Copy this file to .env.local and fill in your real values.

# Required for Spotify search and track details.
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# Optional but needed for live model audio-features calls and the third-party API baseline.
RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_RECOMMENDATIONS_MARKET=FR
RAPIDAPI_RECOMMENDATIONS_LIMIT=10
# RAPIDAPI_RECOMMENDATIONS_SEED_GENRES=electro,techno

# Folder that contains the exported model files.
MODEL_DATA_DIR=model-data

# Optional: model D selects one random track from this many highest-popularity dataset tracks.
POPULARITY_BASELINE_TOP_N=100

# Local study mode: 1 shows real model names and detailed notes.
# For blind deployed evaluation, set this to 0 in Railway variables.
SHOW_MODEL_NAMES=1

# Optional: protect /admin with a password.
# ADMIN_PASSWORD=choose_a_private_password
# Optional for deployment: random text used to sign browser sessions.
# FLASK_SECRET_KEY=choose_a_long_random_string

# Optional: use Postgres instead of the local sqlite file.
# Railway/Render can give you this value.
# DATABASE_URL=postgresql://user:password@host:5432/database_name

